\f0\fs24 \cf0 """\
DaveLLM Router \'96 A minimal FastAPI application for routing prompts to local llama.cpp nodes.\
\
This starter code demonstrates how to forward chat requests to one of several nodes.\
You can expand this router with more sophisticated routing logic, metrics, streaming,\
and discovery as your project grows.\
"""\
\
from typing import List, Optional\
from fastapi import FastAPI, HTTPException\
from pydantic import BaseModel\
import os\
import random\
import requests\
\
app = FastAPI(title="DaveLLM Router", description="Routes chat prompts to available nodes", version="0.1.0")\
\
# Load nodes from environment variable or default to two local nodes\
nodes = [\
    \{"name": "mac-test-node", "url": "http://127.0.0.1:9001"\}\
]\
\
# Actually use the nodes list\
NODES = [node["url"] for node in nodes]\
\
class ChatRequest(BaseModel):\
    prompt: str\
    model: Optional[str] = None\
    max_tokens: Optional[int] = 256\
\
class ChatResponse(BaseModel):\
    response: str\
    node: str\
\
@app.get("/health", tags=["Status"])\
def health() -> dict:\
    """Simple health check."""\
    return \{"status": "ok", "nodes": NODES\}\
\
@app.post("/chat", response_model=ChatResponse, tags=["Chat"])\
def chat(request: ChatRequest) -> ChatResponse:\
    """\
    Forward a chat prompt to one of the configured nodes.\
\
    The router picks a node at random.  In a production setup you might want\
    round\uc0\u8209 robin or least\u8209 loaded routing based on node metrics.\
    """\
    if not NODES:\
        raise HTTPException(status_code=503, detail="No nodes configured")\
\
    node_url = random.choice(NODES)\
    try:\
        # Forward the request to the node's generate endpoint\
        node_endpoint = f"\{node_url\}/generate"\
        resp = requests.post(node_endpoint, json=request.dict(), timeout=60)\
        resp.raise_for_status()\
        data = resp.json()\
        # Expect the node to return a JSON object with at least a 'response' field\
        answer = data.get("response") or data\
        return ChatResponse(response=str(answer), node=node_url)\
    except requests.RequestException as e:\
        raise HTTPException(status_code=502, detail=f"Error contacting node \{node_url\}: \{e\}")\
}